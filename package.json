{
  "name": "pomodoro-timer",
  "version": "2.0.0",
  "description": "桌面番茄钟 - Apple Style Pomodoro Timer",
  "main": "main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:1420 && cross-env NODE_ENV=development electron --no-sandbox .\"",
    "build": "vite build",
    "build:electron": "vite build && electron-builder --win",
    "start": "electron ."
  },
  "build": {
    "appId": "com.pomodoro.timer",
    "productName": "番茄钟",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallDirectory": true,
      "createDesktopShortcut": true
    }
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^42.0.1",
    "electron-builder": "^25.1.8",
    "postcss": "^8.5.14",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "vite": "^6.4.2",
    "wait-on": "^8.0.5"
  }
}
